LAUNCHER_NAME=Tree SMP
LAUNCHER_APP_ID=moe.sol.tree_smp
LAUNCHER_ICON=packaging/potato_launcher.png
LAUNCHER_DESCRIPTION=Launcher for the Tree SMP modpack
VERSION_MANIFEST_URL=https://mc.sol.moe/pack/version_manifest.json
# Static self-update endpoint served by the tree-site nginx (no backend); the launcher polls
# {BACKEND_API_BASE}/launchers/{os}/{artifact}[/version]. CI bakes VERSION=$GITHUB_SHA so the
# version compare works; local `cargo run` skips auto-update (see should_check_updates).
BACKEND_API_BASE=https://mc.sol.moe/api
