{
    "download_server_base": "https://your.domain/data",
    "replace_download_urls": true,
    "instances": [
        {
            "name": "Monifactory",
            "minecraft_version": "1.20.1",
            "mod_loader": "forge",
            "loader_version": "47.3.7",
            "source_root": "/data/internal/uploaded-instances/Monifactory",
            "content_rules": [
                {
                    "path": "config",
                    "apply_on": "update",
                    "overwrite": false,
                    "type": "directory",
                    "delete_extra": false,
                    "skip_if_dir_exists": true
                },
                {
                    "path": "defaultoptions/options.txt",
                    "apply_on": "update",
                    "type": "config_options",
                    "config_type": "properties",
                    "options": [
                        {
                            "key": "difficulty",
                            "value": "2"
                        }
                    ]
                }
            ],
            "mod_sync": {
                "mode": "delta",
                "required": [
                    "some-required-mod"
                ],
                "blocked": [
                    "some-blocked-mod"
                ],
                "optional_sets": [
                    {
                        "id": "jei",
                        "display_name": "Just Enough Items (JEI)",
                        "enabled_by_default": false,
                        "mod_ids": [
                            "jei-1.20.1-forge-15.2.0.27"
                        ]
                    }
                ]
            },
            "resource_sync": "on_update",
            "auth_backend": {
                "type": "telegram",
                "auth_base_url": "https://your.auth.domain"
            },
            "default_xmx": "8G"
        }
    ]
}
